facet_wrap(~Context, ncol = 1) +
theme_bw() +
labs(
title = "Pharmacological Effect: Drug vs. Vehicle",
subtitle = "Posterior Median and 95% Credible Intervals",
x = "Effect Size (Delta)",
y = "Cognitive Parameter"
) +
theme(legend.position = "none")
print(p_forest)
ggsave("../results/drug_deltas_forest.png", p_forest, width = 8, height = 10)
message("\nAnalysis complete. Results and plots saved to ../results/")
# absolute values ----
# 1. Define the parameters you want to extract
# Replace "mu_phi" with the actual name of your baseline parameter from the Stan file
target_params <- c("phi", "side", "eta_pos", "beta_slope")
# 2. Extract and reconstruct the absolute draws
absolute_draws <- fit %>%
# Gather the baseline (Vehicle) and the delta (Drug effect)
gather_draws(
mu_phi[ctx_id], delta_phi[drug_id, ctx_id],
mu_side[ctx_id], delta_side[drug_id, ctx_id],
mu_eta_pos[ctx_id], delta_eta_pos[drug_id, ctx_id],
mu_beta_slope[ctx_id], delta_beta_slope[drug_id, ctx_id]
) %>%
# Pivot wider so we can do math on them
pivot_wider(names_from = .variable, values_from = .value) %>%
# Calculate the absolute values
mutate(
# If drug_id == 1 (Vehicle), the delta is 0, so Absolute = Baseline
# If drug_id == 2 (Drug), Absolute = Baseline + Delta
abs_phi = mu_phi + delta_phi,
abs_side = mu_side + delta_side,
abs_eta_pos = mu_eta_pos + delta_eta_pos,
abs_beta_slope = mu_beta_slope + delta_beta_slope,
# Label the groups for plotting
Condition = ifelse(drug_id == 1, "Vehicle", "DORA")
) %>%
# Pivot back to long format for easy plotting
select(.chain, .iteration, .draw, Condition, ctx_id, starts_with("abs_")) %>%
pivot_longer(cols = starts_with("abs_"), names_to = "parameter", values_to = "absolute_value")
print(p_absolute)
# 4. Visualization: Side-by-Side Posterior Densities
# Let's plot Context 2 specifically, since it's the "Frustration Peak"
p_absolute <- absolute_draws %>%
filter(ctx_id == 2) %>%
ggplot(aes(x = absolute_value, y = parameter, fill = Condition)) +
stat_halfeye(
alpha = 0.7,
.width = c(0.89, 0.95),
point_interval = median_hdci,
position = position_dodge(width = 0.6) # Separates the Vehicle and Drug distributions
) +
theme_bw() +
scale_fill_manual(values = c("Vehicle" = "gray50", "DORA" = "darkred")) +
labs(
title = "Absolute Cognitive Parameters in Context 2 (0.99 / 0.50)",
subtitle = "Posterior distributions of Vehicle vs. DORA-treated agents",
x = "Absolute Parameter Value",
y = "Cognitive Parameter"
)
# absolute values ----
# 1. Define the parameters you want to extract
# Replace "mu_phi" with the actual name of your baseline parameter from the Stan file
target_params <- c("phi", "side", "eta_pos", "beta_slope")
# 1. Extract baseline and deltas simultaneously using spread_draws.
# This natively handles the mismatch in dimensions!
absolute_draws <- fit %>%
spread_draws(
mu_phi[ctx_id], delta_phi[drug_id, ctx_id],
mu_side[ctx_id], delta_side[drug_id, ctx_id],
mu_eta_pos[ctx_id], delta_eta_pos[drug_id, ctx_id],
mu_beta_slope[ctx_id], delta_beta_slope[drug_id, ctx_id]
) %>%
# Now they are already perfectly aligned in wide format! We just do the math:
mutate(
# Vehicle = Baseline + 0, Drug = Baseline + Delta
abs_phi = mu_phi + delta_phi,
abs_side = mu_side + delta_side,
abs_eta_pos = mu_eta_pos + delta_eta_pos,
abs_beta_slope = mu_beta_slope + delta_beta_slope,
# Label the groups for plotting
Condition = ifelse(drug_id == 1, "Vehicle", "DORA")
) %>%
# Select only the computed absolute values to clean up the dataframe
select(.chain, .iteration, .draw, Condition, ctx_id, starts_with("abs_")) %>%
# Pivot back to long format specifically for ggplot/ggdist
pivot_longer(
cols = starts_with("abs_"),
names_to = "parameter",
values_to = "absolute_value"
)
# 2. Calculate Summary Statistics (Medians and 95% HDIs for the paper)
absolute_summary <- absolute_draws %>%
group_by(parameter, Condition, ctx_id) %>%
summarise(
Median = median(absolute_value),
Lower_95 = quantile(absolute_value, 0.025),
Upper_95 = quantile(absolute_value, 0.975),
.groups = "drop"
)
