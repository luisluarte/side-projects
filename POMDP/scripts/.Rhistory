if (sum(x) == 0) {
return(0)
}
p <- x[x > 0] / sum(x)
entropy <- -sum(p * log2(p))
return(entropy)
}
compute_normalized_entropy <- function(x) {
if (sum(x) == 0 || length(x) <= 1) {
return(0)
}
p <- x[x > 0] / sum(x)
raw_entropy <- -sum(p * log2(p))
max_entropy <- log2(length(x))
if (max_entropy == 0) {
return(0)
}
return(raw_entropy / max_entropy)
}
blobs <- map(1:10000, ~ generate_blob())
entropy_blobs <- map_dbl(blobs, ~ compute_normalized_entropy(.x))
series <- c(
cumsum(rnorm(n = 100, mean = 0.5, sd = 1))
)
blob_operations <- map_dfr(blobs, function(blob) {
blob_operation(blob = blob, series = series)
})
rlang::last_trace()
blob_operation(blobs[[1]], series)
blob_operation <- function(blob, series) {
idx <- sample(1:length(series), size = length(blob), replace = TRUE)
sample <- series[sort(idx)]
print(sample)
c(
input = lm(sample ~ 1:length(blob))$coef[2],
operation = sum(blob * sample),
entropy = compute_normalized_entropy(blob)
)
}
blob_operation(blobs[[1]], series)
