time_rel = time - min(time),
chain = as.factor(chain),
rolling_avg = rollapply(
cbind(sample, time_rel),
width = 10,
FUN = get_slope,
by.column = FALSE,
align = "right",
fill = NA
),
eta = (4000 / rolling_avg) / (60^2)
)
dat_time %>%
drop_na() %>%
ggplot(aes(time_rel, eta)) +
geom_line(aes(color = chain)) +
facet_wrap(~chain)
