generate_random_markov <- function(size) {
m <- matrix(data = numeric(size * size), nrow = size, ncol = size)
return(m)
}
generate_random_markov(3)
generate_random_markov <- function(size) {
m <- matrix(
data = runif(size * size, min = 0, max = 1),
nrow = size, ncol = size
)
return(m)
}
