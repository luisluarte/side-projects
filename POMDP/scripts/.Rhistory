} else {
sigma_obs_sq[] <- var(r_t[-1], na.rm = TRUE)
}
sigma_obs_sq[sigma_obs_sq == 0 | is.na(sigma_obs_sq)] <- 0.001
# Initialize state vectors
mu_hat <- numeric(n)
Sigma  <- numeric(n)
# Initial priors (Week 0)
mu_hat[1] <- 0.0
Sigma[1]  <- 0.01
# Sequential Bayesian Update (1D Kalman Filter)
for (t in 2:n) {
if (!is.na(r_t[t])) {
Sigma_pred <- Sigma[t-1] + Q
K_t <- Sigma_pred / (Sigma_pred + sigma_obs_sq[t])
mu_hat[t] <- mu_hat[t-1] + K_t * (r_t[t] - mu_hat[t-1])
Sigma[t]  <- (1 - K_t) * Sigma_pred
} else {
mu_hat[t] <- mu_hat[t-1]
Sigma[t]  <- Sigma[t-1] + Q
}
}
# Compile into a structured data frame, now including real Dates
results <- data.frame(
date = dates,
price = prices,
log_return = r_t,
obs_variance = sigma_obs_sq,
mu_hat = mu_hat,
sigma_sq = Sigma,
std_err = sqrt(Sigma)
)
return(results)
}
# -------------------------------------------------------------------------
# 2. Data Acquisition: Fetching Real Bitcoin Data
# -------------------------------------------------------------------------
# Suppress warnings for cleaner output
options("getSymbols.warning4.0" = FALSE)
# Fetch BTC-USD data from Yahoo Finance (from 2020 to present)
cat("Fetching BTC-USD data...\n")
getSymbols("BTC-USD", src = "yahoo", from = "2020-01-01", auto.assign = TRUE)
# Convert daily data to weekly data
btc_weekly <- to.weekly(`BTC-USD`)
# Extract the weekly closing prices
btc_close <- as.numeric(Cl(btc_weekly))
btc_dates <- index(btc_weekly)
# -------------------------------------------------------------------------
# 3. Execution & Visualization
# -------------------------------------------------------------------------
# Run the Estimator on real BTC data
# Note: Bitcoin's volatility may require tuning Q. We'll start with Q = 0.0005
# to make it slightly more agile to crypto regime shifts.
results_btc <- bayesian_drift_estimator(prices = btc_close, dates = btc_dates, Q = 0.0005, lookback = 55)
# Plotting the result against real dates
ggplot(results_btc, aes(x = date)) +
geom_hline(yintercept = 0, color = "black", linetype = "dashed", alpha = 0.5) +
geom_ribbon(aes(ymin = mu_hat - std_err, ymax = mu_hat + std_err),
fill = "orange", alpha = 0.3) +
geom_line(aes(y = mu_hat), color = "darkred", linewidth = 1) +
theme_minimal() +
labs(
title = "Bayesian Drift Estimator: BTC-USD (Weekly)",
subtitle = paste("Real empirical data from", min(results_btc$date), "to", max(results_btc$date)),
x = "Date",
y = "Estimated Drift (mu_hat)"
) +
scale_x_date(date_breaks = "1 year", date_labels = "%Y")
